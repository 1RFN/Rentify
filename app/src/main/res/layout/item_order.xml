<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/ivOrderItemImage"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_location_chip" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <TextView
                    android:id="@+id/tvOrderItemTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nama Barang"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvOrderRenterName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Penyewa: User"
                    android:textSize="12sp"
                    android:textColor="@color/gray_text"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/tvOrderDates"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12 Jun - 15 Jun 2026"
                    android:textSize="11sp"
                    android:textColor="@color/gray_text"
                    android:layout_marginTop="1dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvOrderTotalPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 150.000"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/green_rentify" />

                <TextView
                    android:id="@+id/tvOrderStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Menunggu"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutOrderActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/btnRejectOrder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tolak"
                android:textSize="13sp"
                android:textColor="@color/red_rentify"
                android:textStyle="bold"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_mode_unselected"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/btnAcceptOrder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Terima"
                android:textSize="13sp"
                android:textColor="@color/green_rentify"
                android:textStyle="bold"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_mode_unselected" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
