<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_rentify">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="4dp"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pesanan"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/tvOrderCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="0 pesanan"
            android:textSize="13sp"
            android:textColor="@color/gray_text" />
    </RelativeLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/layoutFilterChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chipSemua"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Semua"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_mode_selected"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipMenunggu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_mode_unselected"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:text="Menunggu"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipDisewa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disewa"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_mode_unselected"
                android:textColor="@color/black"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipSelesai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selesai"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_mode_unselected"
                android:textColor="@color/black"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/chipDitolak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ditolak"
                android:textSize="13sp"
                android:textStyle="bold"
                android:paddingHorizontal="20dp"
                android:paddingVertical="8dp"
                android:background="@drawable/bg_mode_unselected"
                android:textColor="@color/black" />
        </LinearLayout>
    </HorizontalScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="20dp"
        android:paddingTop="12dp">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvOrders"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"
            tools:listitem="@layout/item_order" />

        <LinearLayout
            android:id="@+id/layoutEmptyOrders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_gravity="center"
            android:paddingVertical="48dp"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_history"
                app:tint="#D6D6D6"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belum ada pesanan"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pesanan dari penyewa akan muncul di sini."
                android:textColor="@color/gray_text"
                android:textAlignment="center"
                android:textSize="13sp"
                android:paddingHorizontal="32dp" />
        </LinearLayout>

    </FrameLayout>
</LinearLayout>
