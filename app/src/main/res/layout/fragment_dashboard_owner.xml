<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_rentify">

    <!-- Konten utama yang bisa discroll -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingBottom="88dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDashboardName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dashboard Memuat..."
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mode Pemilik"
                        android:background="@drawable/bg_circle_yellow"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_circle_white"
                    android:padding="8dp"
                    android:src="@drawable/ic_notification" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_location_chip"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Barang Aktif"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvStatActiveItems"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/green_rentify"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_location_chip"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginStart="8dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pesanan Masuk"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tvStatIncomingOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FF9800"
                        android:textSize="20sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_location_chip"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pendapatan Bulan Ini (COD)"
                    android:textSize="12sp"/>
                <TextView
                    android:id="@+id/tvStatRevenue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 0"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pesanan Masuk (Menunggu Konfirmasi)"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/tvEmptyOrders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Belum ada pesanan masuk saat ini."
                android:textAlignment="center"
                android:textColor="@color/gray_text"
                android:layout_marginBottom="24dp"
                android:padding="16dp"
                android:background="@drawable/bg_circle_white"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvIncomingOrders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:layout_marginBottom="24dp"/>

            <!-- Header Barang Saya + tombol Lihat Semua -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Barang Saya"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:layout_centerVertical="true"/>

                <TextView
                    android:id="@+id/tvSeeAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="Lihat Semua"
                    android:textSize="13sp"
                    android:textColor="@color/green_rentify"
                    android:textStyle="bold" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tvEmptyItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Anda belum menambahkan barang apapun.\nTekan tombol + untuk mulai menambahkan."
                android:textAlignment="center"
                android:textColor="@color/gray_text"
                android:layout_marginBottom="24dp"
                android:padding="16dp"
                android:lineSpacingMultiplier="1.4"
                android:background="@drawable/bg_circle_white"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMyItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddItem"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Tambah Barang"
        app:tint="@android:color/white"
        app:backgroundTint="#2E7D32" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>