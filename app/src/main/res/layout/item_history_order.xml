<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Baris Atas: Nama Barang & Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvHistoryItemName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Memuat barang..."
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/tvHistoryStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_location_chip" />
        </LinearLayout>

        <!-- Nama Pemilik -->
        <TextView
            android:id="@+id/tvHistoryOwnerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pemilik: ..."
            android:textSize="13sp"
            android:textColor="@color/gray_text"
            android:layout_marginBottom="12dp"/>

        <!-- Tanggal dan Total Harga -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_location_chip"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_history"
                app:tint="@color/gray_text"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvHistoryDates"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="- sampai -"
                android:textSize="12sp"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/tvHistoryPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/green_rentify"/>
        </LinearLayout>

        <!-- Tombol Beri Ulasan (Hanya muncul jika Selesai) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGiveReview"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Beri Ulasan Barang"
            android:textColor="@color/green_rentify"
            app:strokeColor="@color/green_rentify"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>